# Server
PORT=3000

# Email provider (Resend)
# Create an API key in your Resend dashboard.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Outgoing sender identity (must be verified in Resend + DNS-authenticated).
# Spam placement is improved only when SPF, DKIM, and DMARC are configured for this domain.
FROM_EMAIL=Bine Philippines Inc. <contact@binephils.com>

# Internal receiving inboxes for website submissions.
# Set both to the same main company email, or split by department.
CONTACT_TO_EMAIL=bine1@binephils.com
QUOTE_TO_EMAIL=bine1@binephils.com

# Branding used in HTML email templates and links inside notification emails.
# Must match the public site URL (no trailing slash). Used for CORS: forms only submit from this origin + localhost + ALLOWED_ORIGINS + RENDER_EXTERNAL_URL (on Render).
COMPANY_NAME=Bine Philippines Inc.
COMPANY_WEBSITE=https://binephils.com
COMPANY_LOGO_URL=https://binephils.com/images/Logo.png
COMPANY_ADDRESS=Lot 11 Blk 13 Golden Mile Avenue, Golden Mile Business Park, Carmona, Philippines 4116
COMPANY_PHONE=+63 2 8584 4474

# Optional: extra browser origins allowed to POST /api/contact and /api/quote (comma-separated, no spaces or trim each).
# Use if users hit a different hostname than COMPANY_WEBSITE (e.g. https://your-app.onrender.com before DNS points to custom domain).
# On Render Web Services, RENDER_EXTERNAL_URL is injected automatically and does not need to be in .env.
# ALLOWED_ORIGINS=https://your-app.onrender.com
